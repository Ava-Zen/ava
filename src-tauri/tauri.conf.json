{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ava",
  "version": "0.1.3",
  "identifier": "com.ava-zen.ava",
  "build": {
    "frontendDist": "../dist/ava/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ava",
        "width": 420,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
